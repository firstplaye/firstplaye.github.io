<footer id="footer">
  <% if (theme.sidebar === 'bottom'){ %>
    <%- partial('_partial/sidebar') %>
  <% } %>
  <div class="outer" style="display:block;">
    <div id="footer-info" class="inner">
      <% if (theme.copyright){ %>
        <p><%= theme.copyright %></p>
      <% } %>
      <p>&copy; <%= date(new Date(), 'YYYY') %> <%= config.author || config.title %> · <%= __('powered_by') %> <a href="https://hexo.io/" target="_blank">Hexo</a></p>
    </div>
  </div>
</footer>
